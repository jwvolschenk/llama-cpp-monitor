# Copy to .env and fill in values:
#   cp .env.example .env

# llama.cpp server
LLAMA_HOST=localhost
LLAMA_PORT=8080
LLAMA_API_KEY=

# Monitor dashboard
MONITOR_PORT=8100
GPU_INDEX=1
POLL_INTERVAL=1
HISTORY_MAX=300
HISTORY_HOUR_MAX=3600
HISTORY_24H_MAX=86400

# Frontier cost comparison (ZAR per USD)
USD_TO_ZAR=17

# Local GPU electricity estimate (ZAR per kWh)
ZAR_PER_KWH=2

# Persisted session state (token totals, energy); survives restarts
# STATE_FILE=data/monitor_state.json
# STATE_SAVE_INTERVAL=30
